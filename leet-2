class Solution:
    def reverseKGroup(self, head: Optional[ListNode], k: int) -> Optional[ListNode]:
        dummy = ListNode(0, head)
        groupPrev = dummy
        
        while True:
            # 1. Find the k-th node (the end of the current group)
            kth = self.getKth(groupPrev, k)
            if not kth:
                break
            groupNext = kth.next # The start of the NEXT group
            
            # 2. Reverse the current group
            prev, curr = groupNext, groupPrev.next
            while curr != groupNext:
                tmp = curr.next
                curr.next = prev
                prev = curr
                curr = tmp
            
            # 3. Re-link the group into the main list
            tmp = groupPrev.next # Store the original head (now the tail)
            groupPrev.next = kth # Link previous group to the new head (kth)
            groupPrev = tmp      # Move groupPrev to the end of this group
            
        return dummy.next

    def getKth(self, curr, k):
        while curr and k > 0:
            curr = curr.next
            k -= 1
        return curr
