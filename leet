from collections import Counter

class Solution:
    def findSubstring(self, s: str, words: List[str]) -> List[int]:
        if not s or not words:
            return []
        
        word_len = len(words[0])
        word_count = len(words)
        total_len = word_len * word_count
        word_map = Counter(words)
        res = []
        
        # Iterate over all possible starting offsets (0 to word_len - 1)
        for i in range(word_len):
            left = i
            right = i
            current_map = Counter()
            count = 0
            
            # Slide the window across the string
            while right + word_len <= len(s):
                # Extract the word at the right end of the window
                word = s[right:right + word_len]
                right += word_len
                
                if word in word_map:
                    current_map[word] += 1
                    count += 1
                    
                    # If we have too many instances of 'word', shrink from the left
                    while current_map[word] > word_map[word]:
                        left_word = s[left:left + word_len]
                        current_map[left_word] -= 1
                        count -= 1
                        left += word_len
                    
                    # If the window size matches the total words length, we found a match
                    if count == word_count:
                        res.append(left)
                else:
                    # Not a valid word, reset the window
                    current_map.clear()
                    count = 0
                    left = right
                    
        return res
