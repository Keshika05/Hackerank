class Solution:
    def longestValidParentheses(self, s: str) -> int:
        stack = [-1] # Base index
        max_len = 0
        
        for i, char in enumerate(s):
            if char == '(':
                stack.append(i)
            else:
                stack.pop()
                if not stack:
                    # If empty, this ')' is an anchor for future valid strings
                    stack.append(i)
                else:
                    # Current valid string length is current index minus last anchor
                    max_len = max(max_len, i - stack[-1])
                    
        return max_len
