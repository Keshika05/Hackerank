class Solution:
    def swapPairs(self, head: Optional[ListNode]) -> Optional[ListNode]:
        # Create a dummy node to act as the predecessor of the head
        dummy = ListNode(0, head)
        prev = dummy
        
        while prev.next and prev.next.next:
            # Nodes to be swapped
            first = prev.next
            second = prev.next.next
            
            # Swapping
            # 1. Point prev to the second node
            prev.next = second
            # 2. Point first node to whatever was after second
            first.next = second.next
            # 3. Point second node back to first
            second.next = first
            
            # Move prev pointer forward by two nodes for the next pair
            prev = first
            
        return dummy.next
