import heapq

class Solution:
    def mergeKLists(self, lists: List[Optional[ListNode]]) -> Optional[ListNode]:
        # Min-heap to store (node.val, list_index, node)
        min_heap = []
        
        # 1. Add the head of each non-empty list to the heap
        for i, l in enumerate(lists):
            if l:
                # We include 'i' to handle cases where multiple nodes have the same value
                heapq.heappush(min_heap, (l.val, i, l))
        
        dummy = ListNode(0)
        curr = dummy
        
        # 2. While the heap is not empty, extract the minimum and add its next node
        while min_heap:
            val, i, node = heapq.heappop(min_heap)
            curr.next = node
            curr = curr.next
            
            if node.next:
                heapq.heappush(min_heap, (node.next.val, i, node.next))
                
        return dummy.next
